# MongoDB Atlas (required for cloud persistence on Vercel)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# Optional database name (default: pm_prioritization)
MONGODB_DB_NAME=pm_prioritization

# Workspace document id (default: default) — use one id per deployment/team
PM_WORKSPACE_ID=default

# API secret — browser sends as Bearer token (store in session after first visit)
# Generate: openssl rand -hex 32
PM_API_SECRET=change-me-to-a-long-random-secret

# Dev only: allow GET/PUT without Bearer token (never enable in public production)
# PM_ALLOW_ANONYMOUS=true
